//@version=6
indicator("Crypto Hunters TV Bridge v1", overlay=true, max_labels_count=100)

webhookSecret = input.string("CHANGE_ME", "Webhook secret")
minScore      = input.int(78, "Minimum alert score", minval=0, maxval=100)
useClosedBars = input.bool(true, "Alert only on closed bars")
showTable     = input.bool(true, "Show Hunter score table")

emaFastLen = input.int(9, "EMA fast")
emaMidLen  = input.int(21, "EMA middle")
emaSlowLen = input.int(50, "EMA slow")
rsiLen     = input.int(14, "RSI length")
atrLen     = input.int(14, "ATR length")
rvolLen    = input.int(20, "Relative-volume length")

ema9  = ta.ema(close, emaFastLen)
ema21 = ta.ema(close, emaMidLen)
ema50 = ta.ema(close, emaSlowLen)
rsiValue = ta.rsi(close, rsiLen)
[macdLine, macdSignal, macdHist] = ta.macd(close, 12, 26, 9)
atrValue = ta.atr(atrLen)
atrPct = close != 0 ? atrValue / close * 100 : 0.0
avgVolume = ta.sma(volume, rvolLen)
rvol = avgVolume != 0 ? volume / avgVolume : 0.0

bullStructure = ema9 > ema21 and ema21 > ema50
bearStructure = ema9 < ema21 and ema21 < ema50
bullSlope = ema9 > ema9[3] and ema21 > ema21[3]
bearSlope = ema9 < ema9[3] and ema21 < ema21[3]
bullMacd = macdLine > macdSignal
bearMacd = macdLine < macdSignal
bullAccel = macdHist > macdHist[1]
bearAccel = macdHist < macdHist[1]

longTrend = (bullStructure ? 25 : 0) + (bullSlope ? 10 : 0) + (bullMacd ? 10 : 0) + (rsiValue >= 50 ? 5 : 0)
shortTrend = (bearStructure ? 25 : 0) + (bearSlope ? 10 : 0) + (bearMacd ? 10 : 0) + (rsiValue <= 50 ? 5 : 0)

longEntry = (ta.crossover(ema9, ema21) ? 15 : bullStructure ? 8 : 0) + (bullMacd ? 10 : 0) + (bullAccel ? 8 : 0) + (rsiValue >= 50 and rsiValue <= 68 ? 7 : 0)
shortEntry = (ta.crossunder(ema9, ema21) ? 15 : bearStructure ? 8 : 0) + (bearMacd ? 10 : 0) + (bearAccel ? 8 : 0) + (rsiValue <= 50 and rsiValue >= 32 ? 7 : 0)

volatilityScore = math.min(25.0, atrPct * 8.0) + (rvol >= 2.0 ? 25 : rvol >= 1.5 ? 18 : rvol >= 1.2 ? 10 : 0)
extensionPct = math.abs(close / ema21 - 1) * 100
chasePenalty = extensionPct > 4 ? 15 : extensionPct > 2.5 ? 8 : 0

longScore = math.max(0, math.min(100, longTrend + longEntry + volatilityScore - chasePenalty))
shortScore = math.max(0, math.min(100, shortTrend + shortEntry + volatilityScore - chasePenalty))

longReady = longScore >= minScore and bullStructure and bullMacd
shortReady = shortScore >= minScore and bearStructure and bearMacd
confirmed = useClosedBars ? barstate.isconfirmed : true

direction = longScore >= shortScore ? "LONG" : "SHORT"
bestScore = math.max(longScore, shortScore)
signal = longReady or shortReady ? "ENTRY_WINDOW_OPEN" : "WATCH"

jsonMessage(_direction, _score, _signal) =>
    '{"secret":"' + webhookSecret +
    '","source":"TradingView"' +
    ',"exchange":"' + syminfo.prefix +
    '","symbol":"' + syminfo.ticker +
    '","tickerid":"' + syminfo.tickerid +
    '","timeframe":"' + timeframe.period +
    '","direction":"' + _direction +
    '","signal":"' + _signal +
    '","score":' + str.tostring(_score, "#.0") +
    ',"price":' + str.tostring(close, format.mintick) +
    ',"rsi":' + str.tostring(rsiValue, "#.00") +
    ',"atr_pct":' + str.tostring(atrPct, "#.000") +
    ',"rvol":' + str.tostring(rvol, "#.00") +
    ',"extension_pct":' + str.tostring(extensionPct, "#.00") +
    ',"bar_time":' + str.tostring(time) + '}'

newLong = confirmed and longReady and not longReady[1]
newShort = confirmed and shortReady and not shortReady[1]

if newLong
    alert(jsonMessage("LONG", longScore, "ENTRY_WINDOW_OPEN"), alert.freq_once_per_bar_close)
if newShort
    alert(jsonMessage("SHORT", shortScore, "ENTRY_WINDOW_OPEN"), alert.freq_once_per_bar_close)

longWeakening = confirmed and longReady[1] and (longScore < minScore or bearAccel)
shortWeakening = confirmed and shortReady[1] and (shortScore < minScore or bullAccel)
if longWeakening
    alert(jsonMessage("LONG", longScore, "MOMENTUM_WEAKENING"), alert.freq_once_per_bar_close)
if shortWeakening
    alert(jsonMessage("SHORT", shortScore, "MOMENTUM_WEAKENING"), alert.freq_once_per_bar_close)

plot(ema9, "EMA 9", color=color.new(color.green, 0))
plot(ema21, "EMA 21", color=color.new(color.orange, 0))
plot(ema50, "EMA 50", color=color.new(color.blue, 0))
plotshape(newLong, title="Hunter LONG", style=shape.labelup, location=location.belowbar, text="LONG", color=color.green, textcolor=color.white, size=size.tiny)
plotshape(newShort, title="Hunter SHORT", style=shape.labeldown, location=location.abovebar, text="SHORT", color=color.red, textcolor=color.white, size=size.tiny)

var table hunter = table.new(position.top_right, 2, 7, border_width=1)
if barstate.islast and showTable
    table.cell(hunter, 0, 0, "Hunter")
    table.cell(hunter, 1, 0, syminfo.tickerid)
    table.cell(hunter, 0, 1, "Direction")
    table.cell(hunter, 1, 1, direction)
    table.cell(hunter, 0, 2, "Score")
    table.cell(hunter, 1, 2, str.tostring(bestScore, "#.0"))
    table.cell(hunter, 0, 3, "ATR %")
    table.cell(hunter, 1, 3, str.tostring(atrPct, "#.00"))
    table.cell(hunter, 0, 4, "RVOL")
    table.cell(hunter, 1, 4, str.tostring(rvol, "#.00"))
    table.cell(hunter, 0, 5, "Extension")
    table.cell(hunter, 1, 5, str.tostring(extensionPct, "#.00") + "%")
    table.cell(hunter, 0, 6, "Signal")
    table.cell(hunter, 1, 6, signal)
